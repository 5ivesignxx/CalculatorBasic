<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1C1E">

    <!-- Expression (e.g. 12 + 5 =) -->
    <TextView
        android:id="@+id/tvExpression"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="4dp"
        android:textColor="#8E8E93"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main number display -->
    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="start"
        android:gravity="end"
        android:maxLines="1"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="72sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvExpression" />

    <!-- Button grid -->
    <GridLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:columnCount="4"
        android:rowCount="5"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDisplay">

        <!-- Row 0 -->
        <Button android:id="@+id/btnClear"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="AC"
            android:textSize="20sp" android:textColor="#FFFFFF"
            android:backgroundTint="#636366" />

        <Button android:id="@+id/btnNegate"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="+/-"
            android:textSize="20sp" android:textColor="#FFFFFF"
            android:backgroundTint="#636366" />

        <Button android:id="@+id/btnBackspace"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="⌫"
            android:textSize="20sp" android:textColor="#FFFFFF"
            android:backgroundTint="#636366" />

        <Button android:id="@+id/btnDivide"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="÷"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#FF9500" />

        <!-- Row 1 -->
        <Button android:id="@+id/btn7"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="7"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3C" />

        <Button android:id="@+id/btn8"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="8"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3C" />

        <Button android:id="@+id/btn9"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="9"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3C" />

        <Button android:id="@+id/btnMultiply"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="×"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#FF9500" />

        <!-- Row 2 -->
        <Button android:id="@+id/btn4"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="4"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3C" />

        <Button android:id="@+id/btn5"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="5"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3C" />

        <Button android:id="@+id/btn6"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="6"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3C" />

        <Button android:id="@+id/btnSubtract"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="−"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#FF9500" />

        <!-- Row 3 -->
        <Button android:id="@+id/btn1"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="1"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3C" />

        <Button android:id="@+id/btn2"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="2"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3C" />

        <Button android:id="@+id/btn3"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="3"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3C" />

        <Button android:id="@+id/btnAdd"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="+"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#FF9500" />

        <!-- Row 4 -->
        <Button android:id="@+id/btn0"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="2" android:layout_rowWeight="1"
            android:layout_columnSpan="2"
            android:layout_margin="6dp"
            android:text="0"
            android:gravity="center"
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3C" />

        <Button android:id="@+id/btnDot"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="."
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3C" />

        <Button android:id="@+id/btnEquals"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="="
            android:textSize="24sp" android:textColor="#FFFFFF"
            android:backgroundTint="#FF9500" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
